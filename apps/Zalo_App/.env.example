# Public Mini App identifier for zmp-cli. Replace after creating the app in Developer Center.
APP_ID=replace-with-zalo-mini-app-id

# The same public identifier is exposed to the Vite runtime; it is not a token or secret.
VITE_ZALO_MINI_APP_ID=replace-with-zalo-mini-app-id

# DEVELOPMENT_ONLY: allows the shell to run without the Zalo container during browser development.
VITE_ZALO_BROWSER_DEVELOPMENT=true

# DEVELOPMENT_ONLY Mock Central connection. Mock auth is rejected by production builds.
VITE_CENTRAL_API_BASE_URL=http://127.0.0.1:3002/api/v1
VITE_CENTRAL_AUTH_MODE=mock
VITE_MOCK_ZALO_ACCESS_TOKEN=mock-zalo-token-user-a
