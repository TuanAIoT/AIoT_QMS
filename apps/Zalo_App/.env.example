# Public Mini App identifier for zmp-cli. App ID is public, not a token or secret.
# Replace with the Development App ID from Zalo Developer Center when deploying.
APP_ID=replace-with-zalo-mini-app-id

# The same public identifier is exposed to the Vite runtime.
VITE_ZALO_MINI_APP_ID=replace-with-zalo-mini-app-id

# DEVELOPMENT_ONLY: allows local browser testing without the Zalo container.
VITE_ZALO_BROWSER_DEVELOPMENT=true

# DEVELOPMENT_ONLY mock API. This is not the production backend.
VITE_QMS_API_BASE_URL=http://127.0.0.1:3003
