{
  "name": "@qms/zalo-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "zmp:build": "vite build && zmp sync-config dist/index.html",
    "zmp:init": "node -e \"const fs=require('node:fs'); if(fs.existsSync('app-config.json')) { console.error('ZMP project is already initialized; refusing to overwrite app-config.json.'); process.exit(1); }\" && zmp init",
    "zmp:sync-config": "zmp sync-config dist/index.html",
    "zmp:deploy": "zmp deploy --existing --outputDir dist"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zmp-sdk": "2.51.4"
  },
  "devDependencies": {
    "@testing-library/react": "16.2.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "jsdom": "26.0.0",
    "typescript": "5.8.2",
    "vite": "6.2.2",
    "vitest": "3.0.8",
    "zmp-cli": "4.0.3"
  }
}
