{
  "name": "qms-tuan-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Local-First QMS frontend, Linux service, and development tooling workspace",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:display-central": "pnpm --filter @qms/display-central dev",
    "dev:display-service-quality": "pnpm --filter @qms/display-service-quality dev",
    "dev:web-admin-local": "pnpm --filter @qms/web-admin-local dev",
    "dev:web-central-admin": "pnpm --filter @qms/web-central-admin dev",
    "dev:web-teller": "pnpm --filter @qms/web-teller dev",
    "dev:zalo-app": "pnpm --filter @qms/zalo-app dev",
    "dev:mock-zalo-qms": "pnpm --filter @qms/mock-zalo-qms-server dev",
    "dev:linux-audio-service": "pnpm --filter @qms/linux-audio-service dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "eslint": "9.22.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.0.0",
    "prettier": "3.5.3",
    "typescript": "5.8.2",
    "typescript-eslint": "8.26.0"
  }
}
