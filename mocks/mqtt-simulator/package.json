{
  "name": "@qms/mqtt-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "dev": "tsx src/main.ts",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "pnpm build && tsc -p tsconfig.test.json --noEmit && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@qms/contracts": "workspace:*",
    "@qms/mqtt-client": "workspace:*",
    "@qms/seed-data": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  }
}
